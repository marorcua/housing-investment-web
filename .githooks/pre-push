#!/bin/bash
set -euo pipefail

API_DIR="${API_DIR:-../housing-investment-api}"
if [ ! -d "$API_DIR" ]; then
  echo "⚠  API project not found at $API_DIR, skipping e2e tests"
  exit 0
fi

# free ports used by e2e tests
lsof -ti :3001,4321 2>/dev/null | xargs kill -9 2>/dev/null || true

echo "→ pre-push: running e2e tests..."
npm run test:e2e
